# ── Database ──────────────────────────────────────────────────────────────────
# Option A: full connection URL (takes precedence over individual vars)
DATABASE_URL=postgresql://postgres:password@localhost:5432/finance_dashboard

# Option B: individual connection parameters
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=finance_dashboard
PG_USER=postgres
PG_PASSWORD=password

# Test database (used when NODE_ENV=test)
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/finance_dashboard_test
PG_TEST_DATABASE=finance_dashboard_test

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Auth (optional) ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1h
